APP_NAME=xrxs-263-sync
LOG_LEVEL=INFO
TIMEZONE=Asia/Shanghai
SYNC_INTERVAL_MINUTES=60
DRY_RUN=true

STATE_DB_PATH=/data/sync-state.db

SYNC_DISABLE_ABSENT_USERS=false
SYNC_DELETE_ABSENT_USERS=false
SYNC_UPDATE_PASSWORD=false
SYNC_DEFAULT_PASSWORD=replace_me
SYNC_FORCE_CHANGE_PASSWORD=true
SYNC_USERID_MODE=email_localpart
SYNC_NAME_PRESERVE_USERIDS=

XRXS_ADAPTER=twohaohr
XRXS_BASE_URL=https://api.xinrenxinshi.com
XRXS_ACCESS_TOKEN=
XRXS_TOKEN_ENDPOINT=/authorize/oauth/token
XRXS_CLIENT_ID=replace_me
XRXS_CLIENT_SECRET=replace_me
XRXS_DEPARTMENTS_ENDPOINT=/v5/department/list
XRXS_EMPLOYEES_BY_DEPARTMENT_ENDPOINT=/v5/employee/list
XRXS_EMPLOYEE_BASE_INFO_ENDPOINT=/api/employees/base_info/
XRXS_PAGE_SIZE=100
XRXS_FETCH_CHILD_DEPARTMENTS=true
XRXS_COMPANY_ID=

MAIL263_ENDPOINT_URL=https://macom.263.net/api/mail/v2
MAIL263_WSDL_URL=
MAIL263_DOMAIN=example.com
MAIL263_ACCOUNT=example.com
MAIL263_KEY=replace_me
MAIL263_ADMIN_USERID=admin
MAIL263_GID=33
MAIL263_ROLE_ID=0
MAIL263_REQUEST_TIMEOUT_SECONDS=30
MAIL263_RETRY_MAX_ATTEMPTS=5
MAIL263_RETRY_INITIAL_DELAY_SECONDS=3
MAIL263_RETRY_BACKOFF_MULTIPLIER=2
MAIL263_REQUEST_INTERVAL_SECONDS=0.3

MAIL263_SSO_ENABLED=true
MAIL263_PARTNER_ID=replace_me
MAIL263_AUTH_CORP_ID=example.com
MAIL263_SSO_KEY=
MAIL263_SSO_BASE_URL=https://weixin.263.net/partner/web/third/mail/loginMail.do
